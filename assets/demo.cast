[0.000782, "o", "  Result:  BLOCKED\r\n  Scanner: dlp\r\n  Reason:  DLP match: AWS Access ID (critical)\r\n  Score:   1.00\r\nurl blocked\r\n"]
[1.501196, "o", "\r\n\u001b[1m3. Agent tries DNS exfiltration\u001b[0m\r\n"]
[1.501351, "o", "\u001b[0;36m$ pipelock check --url \"https://exfil-c2VjcmV0X2tleV92YWx1ZQ.attacker.com/\"\u001b[0m\r\n"]
