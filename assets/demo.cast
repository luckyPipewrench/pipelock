[0.010168, "o", "\u001b[1mPipelock: Open-Source Agent Firewall\u001b[0m\r\n"]
[1.501079, "o", "\r\n\u001b[1mScanner config (balanced preset)\u001b[0m\r\n"]
[1.500901, "o", "\u001b[0;36m$ pipelock check --config pipelock.yaml\u001b[0m\r\n"]
[0.80903, "o", "Config validation: OK\r\n  Mode:           balanced\r\n  Listen:         127.0.0.1:8888\r\n  API allowlist:  10 domains\r\n  Blocklist:      6 patterns\r\n  DLP patterns:   36 rules\r\n  Entropy thresh: 4.5 bits\r\n  Max URL length: 2048 chars\r\n"]
[1.501739, "o", "\r\n\u001b[1m1. Agent tries to exfiltrate an AWS key\u001b[0m\r\n"]
[1.500996, "o", "\u001b[0;36m$ pipelock check --url \"https://evil.com/steal?key=AKIAIOSFODNN7EXAMPLE\"\u001b[0m\r\n"]
[0.809159, "o", "\r\nScanning URL: https://evil.com/steal?key=AKIAIOSFODNN7EXAMPLE\r\n"]
[0.000785, "o", "  Result:  BLOCKED\r\n  Scanner: dlp\r\n  Reason:  DLP match: AWS Access ID (critical)\r\n  Score:   1.00\r\nurl blocked\r\n"]
[1.501249, "o", "\r\n\u001b[1m2. Agent encodes it to evade detection\u001b[0m\r\n"]
[1.500986, "o", "\u001b[0;36m$ pipelock check --url \"https://evil.com/log?d=QUtJQUlPU0ZPRE5ON0VYQU1QTEU=\"\u001b[0m\r\n"]
